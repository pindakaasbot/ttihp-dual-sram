{
  "//": "Dual 512x64 SRAM test — two RM_IHPSG13_1P_512x64_c2_bm_bist macros",

  "PL_TARGET_DENSITY_PCT": 60,
  "CLOCK_PERIOD": 20,
  "PL_RESIZER_HOLD_SLACK_MARGIN": 0.1,
  "GRT_RESIZER_HOLD_SLACK_MARGIN": 0.05,

  "RUN_LINTER": 1,
  "LINTER_INCLUDE_PDK_MODELS": 1,
  "CLOCK_PORT": "clk",

  "//": "SRAM macro integration — 2 instances of 512x64",
  "MACROS": {
    "RM_IHPSG13_1P_512x64_c2_bm_bist": {
      "instances": {
        "sram0": {
          "location": [40, 40],
          "orientation": "N"
        },
        "sram1": {
          "location": [40, 280],
          "orientation": "N"
        }
      },
      "gds": [
        "dir::../macro/RM_IHPSG13_1P_512x64_c2_bm_bist/RM_IHPSG13_1P_512x64_c2_bm_bist.gds"
      ],
      "lef": [
        "dir::../macro/RM_IHPSG13_1P_512x64_c2_bm_bist/RM_IHPSG13_1P_512x64_c2_bm_bist.lef"
      ],
      "lib": {
        "nom_*": [
          "dir::../macro/RM_IHPSG13_1P_512x64_c2_bm_bist/RM_IHPSG13_1P_512x64_c2_bm_bist_typ_1p20V_25C.lib"
        ],
        "min_*": [
          "dir::../macro/RM_IHPSG13_1P_512x64_c2_bm_bist/RM_IHPSG13_1P_512x64_c2_bm_bist_fast_1p32V_m55C.lib"
        ],
        "max_*": [
          "dir::../macro/RM_IHPSG13_1P_512x64_c2_bm_bist/RM_IHPSG13_1P_512x64_c2_bm_bist_slow_1p08V_125C.lib"
        ],
        "*": [
          "dir::../macro/RM_IHPSG13_1P_512x64_c2_bm_bist/RM_IHPSG13_1P_512x64_c2_bm_bist_typ_1p20V_25C.lib"
        ]
      },
      "nl": [
        "dir::./RM_IHPSG13_1P_512x64_c2_bm_bist.v"
      ],
      "spice": [
        "dir::../macro/RM_IHPSG13_1P_512x64_c2_bm_bist/RM_IHPSG13_1P_512x64_c2_bm_bist.cdl"
      ]
    }
  },
  "PDN_MACRO_CONNECTIONS": [
    "sram0 VPWR VGND VDD! VSS!",
    "sram0 VPWR VGND VDDARRAY! VSS!",
    "sram1 VPWR VGND VDD! VSS!",
    "sram1 VPWR VGND VDDARRAY! VSS!"
  ],

  "//": "Custom PDN config: SRAM power pins are on Metal4, need Metal4↔TopMetal1 connection",
  "PDN_CFG": "dir::pdn_cfg.tcl",

  "//": "SRAM GDS patched with PR boundary (layer 189/4) — enables blackbox mode",

  "//": "Wide-metal DRC fix: 0.6um Metal2/Metal3 routing blockage strips around SRAMs",
  "//": "Metal2 bottom-edge excluded: all 348 SRAM signal pins are on Metal2 at y=0",
  "ROUTING_OBSTRUCTIONS": [
    "Metal3 40.00 39.40 824.48 40.00",
    "Metal3 40.00 231.34 824.48 231.94",
    "Metal3 39.40 40.00 40.00 231.34",
    "Metal3 824.48 40.00 825.08 231.34",
    "Metal2 40.00 231.34 824.48 231.94",
    "Metal2 39.40 40.00 40.00 231.34",
    "Metal2 824.48 40.00 825.08 231.34",
    "Metal3 40.00 279.40 824.48 280.00",
    "Metal3 40.00 471.34 824.48 471.94",
    "Metal3 39.40 280.00 40.00 471.34",
    "Metal3 824.48 280.00 825.08 471.34",
    "Metal2 40.00 471.34 824.48 471.94",
    "Metal2 39.40 280.00 40.00 471.34",
    "Metal2 824.48 280.00 825.08 471.34"
  ],

  "//": "Run DRC on DEF view (abstract macros) instead of full GDS — skips SRAM internals",
  "MAGIC_DRC_USE_GDS": false,
  "ERROR_ON_MAGIC_DRC": false,

  "//": "Blackbox SRAM macros during SPICE extraction for LVS — skip SRAM transistors",
  "MAGIC_EXT_ABSTRACT_CELLS": ["RM_IHPSG13_1P_.*"],

  "//": "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!",
  "//": "!!! DO NOT CHANGE ANYTHING BELOW THIS POINT !!!",
  "//": "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!",

  "//": "Save some time",
  "RUN_KLAYOUT_XOR": 0,
  "RUN_KLAYOUT_DRC": 0,

  "//": "Don't put clock buffers on the outputs",
  "DESIGN_REPAIR_BUFFER_OUTPUT_PORTS": 0,

  "//": "Reduce wasted space",
  "TOP_MARGIN_MULT": 1,
  "BOTTOM_MARGIN_MULT": 1,
  "LEFT_MARGIN_MULT": 6,
  "RIGHT_MARGIN_MULT": 6,

  "//": "Absolute die size",
  "FP_SIZING": "absolute",

  "GRT_ALLOW_CONGESTION": 1,

  "FP_IO_HLENGTH": 2,
  "FP_IO_VLENGTH": 2,

  "FP_PDN_VPITCH": 38.87,

  "//": "Clock",
  "RUN_CTS": 1,

  "//": "Don't generate power rings",
  "FP_PDN_MULTILAYER": 0,

  "//": "MAGIC_DEF_LABELS may cause issues with LVS",
  "MAGIC_DEF_LABELS": 0,

  "//": "Only export pin area in LEF (without any connected nets)",
  "MAGIC_WRITE_LEF_PINONLY": 1
}
